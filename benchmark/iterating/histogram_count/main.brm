fn main() Int {
    values := [0]
    for i := range 260000 {
        values.push((i * 17 + 5) % 256)
    }

    mut checksum Int = 0
    for round := range 32 {
        counts := [0; 256]
        for _, v := range values {
            counts[v] = counts[v] + 1
        }

        mut local Int = 0
        for i := range 256 {
            local = local + counts[i] * (i + 1 + (round % 3))
        }
        checksum = checksum + local
    }

    println(checksum as String)
    return 0
}
