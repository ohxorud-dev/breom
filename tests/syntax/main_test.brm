enum MaybeInt {
    Some(Int)
    None
}

enum NestedMaybeInt {
    Wrap(MaybeInt)
    Empty
}

interface Named {
    fn name(self) String
}

struct BaseEntity {
    id Int

    pub fn next_id(self) Int {
        return self.id + 1
    }
}

struct PointInfo {
    x Int

    pub fn inc(self) Int {
        return self.x + 1
    }
}

struct UserEntity: BaseEntity, Named {
    point info PointInfo
    title String

    pub fn name(self) String {
        return self.title
    }
}

struct LeftParent {
    left Int

    pub fn left_value(self) Int {
        return self.left
    }
}

struct RightParent {
    right Int

    pub fn right_value(self) Int {
        return self.right
    }
}

struct MultiEntity: LeftParent, RightParent {
    label String
}

struct CollisionA {
    pub fn pick(self) Int {
        return 1
    }
}

struct CollisionB {
    pub fn pick(self) Int {
        return 2
    }
}

struct CollisionEntity: CollisionA, CollisionB {}

@resolve_inherit("method:pick", "CollisionB")
struct ResolvedCollisionEntity: CollisionA, CollisionB {}

struct OverrideCollisionEntity: CollisionA, CollisionB {
    @inherit_from("CollisionA")
    pub fn pick(self) Int {
        return 77
    }
}

@test
fn match_enum_pattern_binds_payload() {
    v := MaybeInt { __tag: 0, __payload0: 41 }
    mut got Int = 0
    match v {
        Some(x) => {
            got = x
        }
        _ => {
            got = -1
        }
    }
    assert(got == 41)
}

@test
fn struct_inheritance_inherits_fields_and_methods() {
    user := UserEntity { id: 7, info: PointInfo { x: 99 }, title: "neo" }
    assert(user.id == 7)
    assert(user.next_id() == 8)
    assert(user.name() == "neo")
}

@test
fn multiple_concrete_inheritance_inherits_all_parent_members() {
    item := MultiEntity { left: 10, right: 20, label: "ok" }
    assert(item.left == 10)
    assert(item.right == 20)
    assert(item.left_value() == 10)
    assert(item.right_value() == 20)
}

@test
@compile_fail(
    "Ambiguous inherited method"
)
fn multiple_concrete_inheritance_reports_ambiguous_method() Int {
    value := CollisionEntity {}
    return value.pick()
}

@test
fn struct_attribute_resolves_ambiguous_parent_method() {
    value := ResolvedCollisionEntity {}
    assert(value.pick() == 2)
}

@test
fn method_attribute_validates_override_parent_origin() {
    value := OverrideCollisionEntity {}
    assert(value.pick() == 77)
}

@test
fn point_field_promotes_member_access() {
    user := UserEntity { id: 1, info: PointInfo { x: 12 }, title: "a" }
    assert(user.x == 12)
}

@test
fn point_field_promotes_method_call() {
    user := UserEntity { id: 1, info: PointInfo { x: 12 }, title: "a" }
    assert(user.inc() == 13)
}

@test
fn match_nested_enum_pattern_binds_payload() {
    inner := MaybeInt { __tag: 0, __payload0: 77 }
    outer := NestedMaybeInt { __tag: 0, __payload0: inner }
    mut got Int = 0
    match outer {
        Wrap(Some(x)) => {
            got = x
        }
        _ => {
            got = -1
        }
    }
    assert(got == 77)
}
