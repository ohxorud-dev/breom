fn unknown_receiver_member_access_compile_error() Int {
    maker := () -> make_point_for_member()
    return maker().z
}

struct Thermo {
    mut c Float
}

struct NestedMetrics {
    inner Metrics
}

struct GenericBox<T> {
    value T
}

struct IntOnlyBox<T: Int> {
    value T
}

@test
fn float_struct_field_compound_assignment() {
    t := Thermo { c: 1.5 }
    t.c += 0.5
    t.c *= 4.0
    assert(t.c == 8.0)
}

@test
fn member_access_after_function_call_uses_return_type() {
    assert(make_point_for_member().x == 11)
    assert(make_point_for_member().y == 22)
}

@test
fn deep_member_chain_float_field_access() {
    n NestedMetrics = make_nested_metrics()
    assert(n.inner.temp == 10.25)
}

@test
fn deep_member_chain_bool_field_access() {
    n NestedMetrics = make_nested_metrics()
    assert(n.inner.ok == true)
}

@test
fn deep_member_chain_string_field_access() {
    n NestedMetrics = make_nested_metrics()
    label String = n.inner.label
    assert(label == "nested")
}

@test
fn new_throws_constructor_value_slot_success_path() {
    got := get_safe_value(9) instead -1
    assert(got == 9)
}

@test
fn new_throws_constructor_value_slot_error_path() {
    got := get_safe_value(-9) instead -1
    assert(got == -1)
}

@test
fn ternary_parses_and_evaluates_basic_expression() {
    got := (3 > 1) ? 5 : 9
    assert(got == 5)
}

@test
fn ternary_and_postfix_error_propagation_coexist() {
    ok := ternary_with_question_and_colon(3) instead -1
    err := ternary_with_question_and_colon(-3) instead -1

    assert(ok == 11)
    assert(err == -1)
}

