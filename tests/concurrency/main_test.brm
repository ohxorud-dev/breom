@test
fn wait_receives_spawned_value() {
    ch := Channel<Int>.new(10)
    spawn t(ch)

    mut got Int = 0
    wait {
        val := << ch => {
            got = val
        }
    }

    assert(got == 4301)
}

@test
fn wait_multiple_messages_sum() {
    ch := Channel<Int>.new(10)
    spawn send_value(ch, 10)
    spawn send_value(ch, 20)
    spawn send_value(ch, 30)

    mut count Int = 0
    mut sum Int = 0
    for count < 3 {
        wait {
            val := << ch => {
                sum = sum + val
                count = count + 1
            }
        }
    }

    assert(sum == 60)
}

@test
fn wait_multiple_arms_selects_ready_channel() {
    ch_slow := Channel<Int>.new(10)
    ch_fast := Channel<Int>.new(10)

    ch_fast << 22
    spawn send_after(ch_slow, 11, 80)

    mut got Int = 0
    wait {
        v1 := << ch_slow => {
            got = v1
        }
        v2 := << ch_fast => {
            got = v2
        }
    }

    assert(got == 22)
}

@test
fn wait_default_arm_runs_when_no_channel_is_ready() {
    ch := Channel<Int>.new(1)
    mut got Int = 0

    wait {
        v := << ch => {
            got = v
        }
        default => {
            got = 77
        }
    }

    assert(got == 77)
}

@test
fn wait_timeout_arm_runs_after_duration() {
    ch := Channel<Int>.new(1)
    mut got Int = 0

    wait {
        v := << ch => {
            got = v
        }
        timeout(5) => {
            got = 88
        }
    }

    assert(got == 88)
}
