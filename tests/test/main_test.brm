define Ten = 10

@test
fn math_and_constants() {
    assert(Ten == 10)
    assert(1 + 1 == 2)
    assert(3 * 7 == 21)
}

@test
fn helper_usage_and_mutation() {
    x := mul(6, 7)
    assert(x == 42)

    mut n Int = 0
    for n < 5 {
        n = n + 1
    }
    assert(n == 5)
}

@test
fn map_set_side_effects() {
    m := (1: 10, 2: 20)
    m.set(2, 99)
    m.set(3, 30)

    assert(m.len() == 3)
    assert(m.get(2) == 99)
    assert(m.contains(3))
    assert(m.delete(3) == true)
    assert(m.contains(3) == false)

    s := {10, 20, 30}
    s.add(30)
    s.add(40)
    assert(s.len() == 4)
    assert(s.remove(20) == true)
    assert(s.contains(20) == false)
}

@test
fn catch_and_fail_control() {
    ok := divide(8, 2) catch {
        instead -1
    }
    assert(ok == 4)

    failed := divide(8, 0) catch {
        assert(err != 0)
        instead -1
    }
    assert(failed == -1)

    if ok != 4 {
        fail("unexpected result from divide")
    }
}

@test
fn string_and_format_behaviour() {
    s := "hello"
    assert(len(s) == 5)

    n := 42
    txt := n as String
    assert(txt == "42")
}

@test
fn branching_and_loop_invariants() {
    mut i Int = 0
    mut acc Int = 0
    for i < 10 {
        if i % 2 == 0 {
            acc = acc + i
        }
        i = i + 1
    }

    assert(i == 10)
    assert(acc == 20)
}

@test
fn map_and_set_interleaved_updates() {
    m := (1: 1, 2: 2)
    s := {1, 2}

    mut i Int = 0
    for i < 6 {
        m.set(i, i * 10)
        s.add(i)
        i = i + 1
    }

    assert(m.get(5) == 50)
    assert(m.contains(0))
    assert(s.contains(0))
    assert(s.contains(5))
    assert(m.len() == 6)
    assert(s.len() == 6)
}
