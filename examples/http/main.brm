import net.http

fn main() {
    println("Starting HTTP server on port 8080...")

    spawn http.listen(8080, (req http.Request) http.Response -> {
        return http.Response {
            status: 200,
            headers: "X-Powered-By: Breom",
            body: "Hello from Breom HTTP!"
        }
    })

    resp := http.get("127.0.0.1", 8080, "/") instead http.Response {
        status: 500,
        headers: "",
        body: "HTTP request failed"
    }
    println(resp.body)
}
